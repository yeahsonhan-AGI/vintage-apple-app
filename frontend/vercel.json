{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/food/:path*",
      "destination": "/api/food"
    },
    {
      "source": "/api/calendar/:path*",
      "destination": "/api/calendar"
    },
    {
      "source": "/api/fitness/:path*",
      "destination": "/api/fitness"
    },
    {
      "source": "/api/notes/:path*",
      "destination": "/api/notes"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth"
    }
  ]
}
